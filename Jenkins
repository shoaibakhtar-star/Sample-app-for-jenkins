pipeline {
    agent any

    environment {
        AWS_REGION = "us-east-1"
        ECR_REPO = "public.ecr.aws/b2o6y9f9/ecr-first-repo"
        IMAGE_TAG = "latest"
        EC2_IP = "13.206.123.40"
    }

    stages {

        stage('Clone') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t ecr-first-repo .'
            }
        }

        stage('Login to Public ECR') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                    aws ecr-public get-login-password --region $AWS_REGION \
                    | docker login --username AWS --password-stdin public.ecr.aws/b2o6y9f9
                    '''
                }
            }
        }

        stage('Tag Image') {
            steps {
                sh 'docker tag ecr-first-repo:latest $ECR_REPO:$IMAGE_TAG'
            }
        }

        stage('Push to Public ECR') {
            steps {
                sh 'docker push $ECR_REPO:$IMAGE_TAG'
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(['vm-ssh-key']) {
                    sh """
                    ssh -o StrictHostKeyChecking=no ubuntu@$EC2_IP << EOF

                    docker pull $ECR_REPO:$IMAGE_TAG

                    docker stop app || true
                    docker rm app || true

                    docker run -d -p 80:8000 --name app $ECR_REPO:$IMAGE_TAG

                    EOF
                    """
                }
            }
        }
    }
}